  "shareTarget": {
    "action": "https://ambijat.github.io/gym-companion/log.html",
    "method": "GET",
    "params": {
      "title": "shared_title",
      "text": "shared_text",
      "url": "shared_url"
    }
  },
  "orientation": "portrait",
  "fingerprints": [],
  "additionalTrustedOrigins": [],
  "retainedBundles": [],
  "protocolHandlers": [
    {
      "protocol": "web+gymcompanion",
      "url": "https://ambijat.github.io/gym-companion/log.html?protocol=%s"
    }
  ],
  "fileHandlers": [],
  "launchHandlerClientMode": "navigate-existing",
  "displayOverride": [
    "standalone",
    "minimal-ui"
  ],
  "appVersion": "1"
