  "maskableIconUrl": "https://ambijat.github.io/gym-companion/icons/icon-512-maskable.png",
  "monochromeIconUrl": "https://ambijat.github.io/gym-companion/icons/icon-192.png",
  "splashScreenFadeOutDuration": 300,
  "signingKey": {
    "path": "android.keystore",
    "alias": "gymcomp"
  },
  "appVersionName": "1",
  "appVersionCode": 1,
  "shortcuts": [
    {
      "name": "Workout Log",
      "shortName": "Log",
      "url": "https://ambijat.github.io/gym-companion/log.html",
      "chosenIconUrl": "https://ambijat.github.io/gym-companion/icons/icon-192.png"
    }
  ],
  "generatorApp": "bubblewrap-cli",
  "webManifestUrl": "https://ambijat.github.io/gym-companion/manifest.json",
  "fallbackType": "customtabs",
  "features": {},
  "alphaDependencies": {
    "enabled": false
  },
  "enableSiteSettingsShortcut": true,
  "isChromeOSOnly": false,
  "isMetaQuest": false,
  "fullScopeUrl": "https://ambijat.github.io/gym-companion/",
