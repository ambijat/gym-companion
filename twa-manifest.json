{
  "packageId": "com.ambijat.gymcompanion",
  "host": "ambijat.github.io",
  "name": "Gym Companion",
  "launcherName": "GymComp",
  "display": "standalone",
  "themeColor": "#0C0E0D",
  "themeColorDark": "#000000",
